{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Luno Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/apps/extension"
      ],
      "outFiles": ["${workspaceFolder}/apps/extension/dist/**/*.js"],
      "preLaunchTask": "luno: build"
    }
  ]
}
